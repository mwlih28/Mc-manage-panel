generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String    @unique
  password     String
  firstName    String
  lastName     String
  role         String    @default("USER")
  rootAdmin    Boolean   @default(false)
  language     String    @default("en")
  twoFactor        Boolean   @default(false)
  twoFactorSecret  String?
  avatarUrl        String?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  // Set when the account was created via, or later linked to, Discord OAuth
  // login. Null for accounts that only ever used email/password.
  discordId         String?   @unique
  discordUsername   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLogin    DateTime?

  servers           Server[]
  apiKeys           ApiKey[]
  activities        Activity[]
  subUserServers    ServerSubUser[]
  pushSubscriptions PushSubscription[]
}

model Node {
  id                  String    @id @default(uuid())
  name                String    @unique
  description         String?
  fqdn                String
  scheme              String    @default("https")
  port                Int       @default(8080)
  daemonPort          Int       @default(2022)
  memory              Int
  memoryOverallocate  Int       @default(0)
  disk                Int
  diskOverallocate    Int       @default(0)
  cpu                 Int       @default(0)
  uploadSize          Int       @default(100)
  daemonSftp          Int       @default(2022)
  daemonBase          String    @default("/var/lib/pterodactyl/volumes")
  behindProxy         Boolean   @default(false)
  maintenanceMode     Boolean   @default(false)
  token               String    @unique
  gameSubdomain       String?
  status              String    @default("OFFLINE")
  // One-time bootstrap code for the install-wings.sh --panel/--code
  // auto-activation flow — separate from the long-lived `token` above,
  // which is what Wings actually authenticates with after setup.
  setupToken          String?   @unique
  setupTokenExpiresAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  allocations  Allocation[]
  servers      Server[]
}

model Allocation {
  id         String   @id @default(uuid())
  nodeId     String
  ip         String
  ipAlias    String?
  port       Int
  notes      String?
  assigned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  node       Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  server     Server?  @relation("ServerAllocation")

  @@unique([nodeId, port])
}

model Egg {
  id              String   @id @default(uuid())
  nestId          String
  uuid            String   @unique @default(uuid())
  author          String
  name            String
  description     String?
  dockerImage     String
  configFiles     String   @default("[]")
  configStartup   String   @default("{}")
  configStop      String   @default("^C")
  configLogs      String   @default("{}")
  startup         String
  scriptInstall   String?
  scriptEntry     String   @default("bash")
  scriptContainer String   @default("alpine:3.4")
  copyScriptFrom  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  nest        Nest     @relation(fields: [nestId], references: [id])
  variables   EggVariable[]
  servers     Server[]
}

model Nest {
  id          String   @id @default(uuid())
  uuid        String   @unique @default(uuid())
  author      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eggs        Egg[]
}

model EggVariable {
  id           String   @id @default(uuid())
  eggId        String
  name         String
  description  String?
  envVariable  String
  defaultValue String   @default("")
  userViewable Boolean  @default(true)
  userEditable Boolean  @default(true)
  rules        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  egg          Egg      @relation(fields: [eggId], references: [id], onDelete: Cascade)
}

model Server {
  id              String   @id @default(uuid())
  externalId      String?  @unique
  uuid            String   @unique @default(uuid())
  uuidShort       String   @unique
  userId          String
  nodeId          String
  eggId           String
  allocationId    String?  @unique
  name            String
  description     String?
  status          String   @default("INSTALLING")
  skipScripts     Boolean  @default(false)
  suspended       Boolean  @default(false)
  memory          Int
  swap            Int      @default(0)
  disk            Int
  io              Int      @default(500)
  cpu             Int      @default(0)
  threads         String?
  oomDisabled     Boolean  @default(false)
  startup         String
  image           String
  env             String   @default("{}")
  eulaAccepted    Boolean  @default(false)
  databaseLimit   Int      @default(0)
  allocationLimit Int      @default(0)
  backupLimit     Int      @default(0)
  // Auto-restart the server if its process exits without an explicit
  // stop request. Wings caps this at a few attempts within a rolling
  // window so a broken config can't boot-loop forever.
  crashDetectionEnabled Boolean @default(true)
  // Automatically mitigate sustained high CPU/memory (e.g. clear dropped
  // -item lag) instead of just letting it ride. See wingsRelay.ts.
  autoOptimizeEnabled   Boolean @default(true)
  // Opt-in public status page (no auth) at /status/:publicSlug — off by
  // default since not every owner wants their server publicly discoverable.
  publicStatusEnabled   Boolean @default(false)
  publicSlug            String? @unique
  // Optional look-and-feel customization for the public status page —
  // an accent color (hex) and a banner image URL. Both fall back to
  // sensible defaults on the page itself when unset.
  publicStatusAccentColor String?
  publicStatusBanner      String?
  publicStatusLogo         String?
  publicStatusAnnouncement String?
  // Raw CSS injected on the public page only (never in the panel) for
  // owners who want full control beyond the built-in options above.
  publicStatusCustomCss    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User       @relation(fields: [userId], references: [id])
  node        Node       @relation(fields: [nodeId], references: [id])
  egg         Egg        @relation(fields: [eggId], references: [id])
  allocation  Allocation? @relation("ServerAllocation", fields: [allocationId], references: [id])
  backups     Backup[]
  databases   Database[]
  activities  Activity[]
  note        ServerNote?
  subUsers    ServerSubUser[]
  schedules   ScheduledTask[]
  statSamples ServerStatSample[]
  webhooks    Webhook[]
  discordBindings DiscordBinding[]
  storeIntegrations StoreIntegration[]

  @@index([userId])
  @@index([nodeId])
}

// Periodic (~1/min, written from the live Wings stats stream) resource
// snapshots, kept for a rolling window so the panel can chart usage over
// hours/days — the in-memory statsBuffer in wingsRelay.ts only covers the
// last couple of minutes and is lost on API restart.
model ServerStatSample {
  id               String   @id @default(uuid())
  serverId         String
  cpu              Float
  memoryBytes      BigInt
  memoryLimitBytes BigInt
  diskBytes        BigInt
  timestamp        DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, timestamp])
}

model Backup {
  id           String    @id @default(uuid())
  serverId     String
  uuid         String    @unique @default(uuid())
  uploadId     String?
  isSuccessful Boolean   @default(false)
  isLocked     Boolean   @default(false)
  name         String
  ignoredFiles String    @default("[]")
  disk         String    @default("local")
  // Resolved storage-backend path/key at upload time — an S3 object key, an
  // SFTP path, or a Google Drive file ID. Pinned at upload time so a later
  // change to the bucket/base-path setting can't orphan existing backups.
  remotePath   String?
  checksum     String?
  bytes        BigInt    @default(0)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  server       Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
}

model Database {
  id             String   @id @default(uuid())
  serverId       String
  databaseHostId String
  databaseName   String
  username       String
  remote         String   @default("%")
  password       String
  maxConnections Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  server         Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  host           DatabaseHost @relation(fields: [databaseHostId], references: [id])
}

model DatabaseHost {
  id           String   @id @default(uuid())
  name         String
  host         String
  port         Int      @default(3306)
  username     String
  password     String
  maxDatabases Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  databases    Database[]
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  name        String
  identifier  String    @unique
  token       String
  permissions String    @default("[]")
  expiresAt   DateTime?
  allowedIps  String    @default("[]")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id         String   @id @default(uuid())
  userId     String?
  serverId   String?
  event      String
  properties String   @default("{}")
  ip         String?
  timestamp  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  server     Server?  @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([serverId, timestamp])
  @@index([userId, timestamp])
  @@index([timestamp])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

// A reusable resource template an admin defines once (e.g. "2GB", "Elite")
// and maps to a store package ID from StoreIntegration.commandMappings
// (loose JSON, same as the packageId->command mapping already there — a
// package on Tebex/CraftingStore/WHMCS has no matching row in this DB, so
// there's nothing to a real foreign key to). Applying a plan on purchase
// updates the server's build limits and, when the node is online, pushes
// the change live via Wings' container.update() — no restart required.
model Plan {
  id              String   @id @default(uuid())
  name            String
  memory          Int
  swap            Int      @default(0)
  disk            Int
  io              Int      @default(500)
  cpu             Int      @default(0)
  databaseLimit   Int      @default(0)
  allocationLimit Int      @default(0)
  backupLimit     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ServerNote {
  id        String   @id @default(uuid())
  serverId  String   @unique
  content   String   @default("")
  updatedAt DateTime @updatedAt

  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model ServerSubUser {
  id          String   @id @default(uuid())
  serverId    String
  userId      String
  permissions String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serverId, userId])
}

model ScheduledTask {
  id             String    @id @default(uuid())
  serverId       String
  name           String
  cronExpression String
  action         String
  payload        String    @default("{}")
  enabled        Boolean   @default(true)
  lastRun        DateTime?
  nextRun        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  server         Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model Webhook {
  id              String    @id @default(uuid())
  name            String
  url             String
  // "generic" (signed JSON, any receiver) or "discord" (Discord embed format)
  mode            String    @default("generic")
  // HMAC signing key for generic mode only — plaintext, same protection
  // tier as other integration secrets (e.g. smtp.pass) since the panel
  // must retain it to sign every future delivery.
  secret          String?
  // JSON array of event keys, e.g. ["server:create","server:power.*"],
  // or ["*"] for everything.
  events          String    @default("[]")
  // null = fires for all servers; set = scoped to one server
  serverId        String?
  enabled         Boolean   @default(true)
  lastStatus      String?
  lastTriggeredAt DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  server          Server?   @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

// Links one Discord channel to one Kretase server so /start /stop /restart
// /status commands in that channel act on that server, without ever needing
// a Discord identity mapped to a Kretase user account. Created via the
// /bind slash command using a short-lived code generated from the panel
// (proves the Discord operator actually has panel access to that server) —
// see services/discordBindCodes.ts.
model DiscordBinding {
  id        String   @id @default(uuid())
  guildId   String
  channelId String   @unique
  serverId  String
  createdAt DateTime @default(now())

  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

// Tracks a single "import from another panel" run so the admin has an audit
// trail/live log to poll — source credentials (API key, SSH password) are
// never persisted here, only held in memory for the duration of the run.
model MigrationJob {
  id        String   @id @default(uuid())
  provider  String   @default("pterodactyl")
  status    String   @default("pending") // pending | running | completed | failed
  // JSON array of { ts, serverName, status: 'ok'|'error', message }
  log       String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A browser's Web Push subscription — lets the panel deliver a real OS-level
// notification (crash, security alert, suspend) even when no tab is open.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tebex/CraftingStore in-game-store integration — the store's own dashboard
// POSTs a purchase webhook here; matching a configured package id runs a
// console command on the mapped server (e.g. granting an in-game rank).
model StoreIntegration {
  id              String    @id @default(uuid())
  provider        String    // "tebex" | "craftingstore"
  name            String
  serverId        String
  webhookSecret   String
  // JSON array of { packageId: string, command: string } — {username} in
  // command is replaced with the buyer's in-game name from the webhook payload.
  commandMappings String    @default("[]")
  enabled         Boolean   @default(true)
  lastTriggeredAt DateTime?
  lastStatus      String?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  server          Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
}
