NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/mcpanel
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=https://your-frontend-domain.vercel.app
APP_NAME=Kretase
APP_URL=https://your-api-domain.railway.app
PANEL_VERSION=1.0.0

# ── Registry SMTP (only needed on the CENTRAL registry server, i.e. mwlih28's server) ──
# Leave these empty on regular panel installations — panel owners configure
# their own SMTP in Admin → Settings → Email instead.
# When set, these take priority over the panel's DB-stored SMTP settings
# for all installer registration emails (thank-you + update notifications).
REGISTRY_SMTP_HOST=smtp.gmail.com
REGISTRY_SMTP_PORT=587
REGISTRY_SMTP_USER=your@gmail.com
REGISTRY_SMTP_PASS=your_app_password_here
REGISTRY_SMTP_FROM=Kretase <noreply@yourdomain.com>
REGISTRY_SMTP_OWNER=your@gmail.com

# Secret key for GitHub Actions to trigger update notifications without JWT auth
# Generate with: openssl rand -hex 32
# Add this same value to GitHub → Settings → Secrets → NOTIFY_WEBHOOK_SECRET
NOTIFY_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32
