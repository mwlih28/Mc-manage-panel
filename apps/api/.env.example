NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/mcpanel
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=https://your-frontend-domain.vercel.app
APP_NAME=Kretase
APP_URL=https://your-api-domain.railway.app
PANEL_VERSION=1.0.0

# STRIPE_CONNECT_PLATFORM_SECRET_KEY — DO NOT set this on your own
# self-hosted install. It belongs only to the Kretase project's own
# canonical deployment (panel.kretase.com), which acts as the one central
# relay every install's "Connect with Stripe" button redirects through
# (Stripe requires a single pre-registered redirect_uri, which can't be
# every self-hosted admin's own domain). Setting this here does nothing
# useful for your own panel — your own Stripe connection lives in
# Admin -> Settings once you click "Connect with Stripe", not in this file.
# STRIPE_CONNECT_PLATFORM_SECRET_KEY=
#
# STRIPE_CONNECT_CLIENT_ID is different — it's the Kretase platform's public
# OAuth application id (safe to be identical on every install, same as any
# OAuth client_id visible in a browser's address bar). It ships hardcoded in
# apps/api/src/routes/stripeConnect.ts once the Kretase project has actually
# registered a Connect platform on Stripe; this env var only exists as an
# override for local/staging testing against a different platform app.
# STRIPE_CONNECT_CLIENT_ID=
